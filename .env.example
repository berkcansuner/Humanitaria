# ============================================================================
# ReliefWeb RAG — ortam değişkenleri (Gemini + Pinecone)
# ============================================================================

# ----------------------------------------------------------------------------
# Google Gemini (chat + sorgu işleme + embedding — OpenAI-uyumlu endpoint)
# ----------------------------------------------------------------------------
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
GEMINI_LLM_MODEL=gemini-3.5-flash      # chat yanıtı
GEMINI_QUERY_MODEL=gemini-2.5-flash    # filtre çıkarma (hızlı/ucuz)
GEMINI_EMBED_MODEL=gemini-embedding-001
EMBED_DIM=3072                         # gemini-embedding-001 → 3072
EMBED_BATCH_SIZE=32

# ----------------------------------------------------------------------------
# Pinecone (serverless vektör DB)
# ----------------------------------------------------------------------------
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX=reliefweb-docs
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=

# ----------------------------------------------------------------------------
# ReliefWeb API
# ----------------------------------------------------------------------------
RELIEFWEB_APPNAME=your_appname_here
RELIEFWEB_BASE_URL=https://api.reliefweb.int/v2

# ----------------------------------------------------------------------------
# RAG retrieval
# ----------------------------------------------------------------------------
CHUNK_SIZE=1500                # karakterler (recursive splitter — 800 kelime → 1500 karakter)
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
MMR_FETCH_K=20                 # MMR aday havuzu
MMR_LAMBDA=0.5                 # 0=maks çeşitlilik, 1=maks alaka
RERANK_ENABLED=True
RERANK_MODEL=bge-reranker-v2-m3        # Pinecone hosted reranker
RERANK_CANDIDATE_MULTIPLIER=4          # aday havuzu = TOP_K_RETRIEVAL * bu
RERANK_BY_DATE=True
DATE_DECAY_FACTOR=0.3
RECENCY_RERANK_POOL=10                 # "current/latest" boost'unda ara alaka havuzu
RECENCY_BOOST_FACTOR=0.6               # boost'ta recency ağırlığı
INGEST_SCHEDULE_HOURS=12

# ----------------------------------------------------------------------------
# API sunucusu
# ----------------------------------------------------------------------------
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=False
RATE_LIMIT=20/minute           # chat endpoint'lerinde IP başına
API_KEY=                       # boş = açık (yerel); doluysa X-API-Key başlığı gerekir
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# ----------------------------------------------------------------------------
# Oturum / sohbet geçmişi
# ----------------------------------------------------------------------------
HISTORY_WINDOW_K=5             # oturum başına tutulan (kullanıcı+asistan) tur sayısı
SESSION_MAX_MEMORY=1000        # in-memory oturum üst sınırı (LRU eviction)
REDIS_URL=                     # opsiyonel: redis://localhost:6379 — boş = in-memory
SESSION_TTL_HOURS=24
CONVERSATION_DB_PATH=./conversations.db   # sidebar sohbetleri (SQLite)

# ----------------------------------------------------------------------------
# Ingestion
# ----------------------------------------------------------------------------
FETCH_PDF_CONTENT=False        # PDF eklerini indir+index'le (yavaş, opsiyonel)
INGEST_WATERMARK_PATH=./.last_ingest.json
INGEST_LOOKBACK_YEARS=3        # --date-from verilmezse manuel ingest tazelik tabanı (0 = sınır yok / tüm geçmiş)
