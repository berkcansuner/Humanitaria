# Ollama Cloud (LLM)
OLLAMA_CLOUD_API_KEY=your_api_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_LLM_MODEL=qwen3.5:397b-cloud

# Ollama Local (Embedding)
OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:8b

# ReliefWeb
RELIEFWEB_API_KEY=your_api_key_here
RELIEFWEB_BASE_URL=https://api.reliefweb.int/v2

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=reliefweb_docs
EMBED_DIM=2560

# Chainlit
CHAINLIT_AUTH_SECRET=change_this_secret
CHAINLIT_USERS=user1:pass1,user2:pass2

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
INGEST_SCHEDULE_HOURS=12
