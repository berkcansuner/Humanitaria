# Ollama Cloud (LLM)
OLLAMA_CLOUD_API_KEY=your_api_key_here
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1
OLLAMA_LLM_MODEL=qwen3.5:397b-cloud

# Ollama Local (Embedding)
OLLAMA_LOCAL_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding:8b

# ReliefWeb
RELIEFWEB_API_KEY=your_api_key_here
RELIEFWEB_APPNAME=your_appname_here
RELIEFWEB_BASE_URL=https://api.reliefweb.int/v2

# ChromaDB
CHROMA_DB_PATH=./chroma_db
CHROMA_COLLECTION=reliefweb_docs
EMBED_DIM=4096        # qwen3-embedding:8b → 4096; 4b variant → 2560
EMBED_BATCH_SIZE=32   # max texts per Ollama embed call

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RETRIEVAL=5
MMR_FETCH_K=20        # candidate pool for MMR retrieval
MMR_LAMBDA=0.5        # 0=max diversity, 1=max relevance
INGEST_SCHEDULE_HOURS=12
RERANK_BY_DATE=True
DATE_DECAY_FACTOR=0.3

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8000

# API Server
API_HOST=127.0.0.1
API_PORT=8000
API_RELOAD=False

# Session history
HISTORY_WINDOW_K=5         # exchanges (user+assistant pairs) kept per session
SESSION_MAX_MEMORY=1000    # max in-memory sessions (LRU eviction beyond this)
REDIS_URL=                 # optional: redis://localhost:6379 — blank = in-memory
SESSION_TTL_HOURS=24       # Redis session TTL (hours)

# Ingestion
FETCH_PDF_CONTENT=False    # download and index PDF attachments (slow, off by default)
